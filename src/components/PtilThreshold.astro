---
---
<div class="threshold-diagram">
  <div style="font-family:var(--ff-mono);font-size:.65rem;color:var(--gold);letter-spacing:.1em;text-transform:uppercase;margin-bottom:.8rem">
    Stripping resistance
  </div>
  <div style="display:flex;align-items:center;gap:0;margin:.5rem 0 1.2rem">
    <div style="flex:2;height:28px;background:linear-gradient(to right,var(--ind),#4444aa);border-radius:4px 0 0 4px;display:flex;align-items:center;padding:0 8px;position:relative">
      <span style="font-family:var(--ff-body);font-size:.78rem;color:white;font-weight:600">
        IND
      </span>
      <div style="position:absolute;top:-24px;right:8px;font-family:var(--ff-mono);font-size:.62rem;color:#ef4444;white-space:nowrap">
        ← Ptil product is here
      </div>
    </div>
    <div style="width:4px;height:44px;background:var(--gold2)"></div>
    <div style="flex:2;height:28px;background:linear-gradient(to right,#4444aa,var(--mbi));display:flex;align-items:center;padding:0 8px">
      <span style="font-family:var(--ff-body);font-size:.78rem;color:white;font-weight:600">
        MBI
      </span>
    </div>
    <div style="flex:1;height:28px;background:linear-gradient(to right,var(--mbi),var(--dbi));border-radius:0 4px 4px 0;display:flex;align-items:center;padding:0 8px">
      <span style="font-family:var(--ff-body);font-size:.78rem;color:white;font-weight:600">
        DBI
      </span>
    </div>
  </div>
</div>
