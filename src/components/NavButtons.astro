---
interface Props {
  prev?: { href: string; label: string };
  next?: { href: string; label: string };
}
const { prev, next } = Astro.props;
---
<div id="nav-btns">
  {prev ? (
    <a class="nb prev" href={prev.href}>← {prev.label}</a>
  ) : <span />}
  {next ? (
    <a class="nb next" href={next.href}>{next.label} →</a>
  ) : <span />}
</div>
