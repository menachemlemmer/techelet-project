---
interface Props {
  prev?: { href: string; label: string };
  next?: { href: string; label: string };
}
const { prev, next } = Astro.props;
---
<div class="nav-btns">
  {prev ? (
    <a class="btn btn-ghost border border-base-300 font-serif text-sm" href={prev.href}>← {prev.label}</a>
  ) : <span />}
  {next ? (
    <a class="btn btn-primary font-serif text-sm" href={next.href}>{next.label} →</a>
  ) : <span />}
</div>

<style>
  .nav-btns {
    display: flex;
    justify-content: space-between;
    margin-top: 3rem;
    padding-top: 1.2rem;
    border-top: 1px solid var(--parch-300);
    gap: 1rem;
  }
</style>
