---
interface Props {
  src: string;
  alt: string;
  caption?: string;
  style?: string;
  imgStyle?: string;
}
const { src, alt, caption, style, imgStyle } = Astro.props;
const id = `lb-${Math.random().toString(36).slice(2,8)}`;
---

<figure class="lightbox-figure" style={style}>
  <img
    src={src}
    alt={alt}
    class="lightbox-thumb"
    style={imgStyle}
    onclick={`document.getElementById('${id}').showModal()`}
    title="Click to enlarge"
  />
  {caption && <figcaption class="lightbox-caption" style="text-align:center;font-size:0.78rem;font-style:italic;color:#6a5a48;font-family:Georgia,serif;margin-top:0.4rem;line-height:1.4;">{caption}</figcaption>}
</figure>

<dialog id={id} class="lightbox-dialog" onclick={`this.close()`}>
  <img src={src} alt={alt} class="lightbox-full" />
  {caption && <p class="lightbox-dialog-caption">{caption}</p>}
</dialog>

<style>
  .lightbox-figure {
    margin: 0;
  }

  .lightbox-thumb {
    cursor: zoom-in;
    display: block;
    width: 100%;
    border-radius: 4px;
    transition: opacity 0.15s ease;
  }

  .lightbox-thumb:hover {
    opacity: 0.88;
  }

  .lightbox-dialog {
    border: none;
    background: transparent;
    max-width: 92vw;
    max-height: 92vh;
    padding: 0;
    outline: none;
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    margin: 0;
  }

  .lightbox-dialog::backdrop {
    background: rgba(0, 0, 0, 0.82);
    cursor: zoom-out;
  }

  .lightbox-full {
    display: block;
    width: 88vw;
    max-height: 85vh;
    border-radius: 4px;
    box-shadow: 0 8px 40px rgba(0,0,0,0.6);
    object-fit: contain;
  }

  .lightbox-dialog-caption {
    color: #e8dcc8;
    font-size: 0.82rem;
    font-style: italic;
    font-family: Georgia, serif;
    text-align: center;
    margin-top: 0.6rem;
    padding: 0 1rem;
  }

  /* ── PRINT ──────────────────────────────────────────────────────────────────
     Component @media print blocks survive Vite's bundler (unlike rules in
     imported global CSS files). Two Chromium print-renderer issues addressed:
     1. The mobile breakpoint (max-width:768px) fires during PDF generation
        (~672px viewport) and sets float:none !important on figures. The
        :global(#content .lightbox-figure[...]) selector has specificity
        (1,2,0) which beats the mobile rule's (1,1,1) unconditionally.
     2. .print-root figure { break-inside:avoid } is set globally in print.css.
        Chromium suppresses float on elements with break-inside:avoid during
        print rendering. Override to auto for floated figures.
     ──────────────────────────────────────────────────────────────────────── */
  @media print {
    :global(#content .lightbox-figure[style*="float:right"]),
    :global(#content .lightbox-figure[style*="float: right"]) {
      float: right !important;
      width: 2.2in !important;
      max-width: 2.2in !important;
      margin: 0 0 0.6rem 1rem !important;
      break-inside: auto !important;
      page-break-inside: auto !important;
    }
    :global(#content .lightbox-figure[style*="float:left"]),
    :global(#content .lightbox-figure[style*="float: left"]) {
      float: left !important;
      width: 2.2in !important;
      max-width: 2.2in !important;
      margin: 0 1rem 0.6rem 0 !important;
      break-inside: auto !important;
      page-break-inside: auto !important;
    }
    :global(.lightbox-dialog) {
      display: none !important;
    }
    /* For floated figures, overlay the caption at the bottom of the image.
       Any break-avoid constraint inside a floated element kills the float in
       Chromium's print renderer, so break-inside:avoid can't keep image and
       caption together. An absolutely-positioned caption inside a
       position:relative figure is part of the image layer — it can never
       appear on a different page, and the caption remains fully readable. */
    :global(#content .lightbox-figure[style*="float"]) {
      position: relative !important;
    }
    :global(#content .lightbox-figure[style*="float"] .lightbox-caption) {
      position: absolute !important;
      bottom: 0 !important;
      left: 0 !important;
      right: 0 !important;
      margin: 0 !important;
      padding: 2px 5px 3px !important;
      background: rgba(255,255,255,0.88) !important;
      color: #1a1208 !important;
      font-size: 0.55rem !important;
      font-style: italic !important;
      line-height: 1.3 !important;
      text-align: center !important;
    }
  }
</style>
