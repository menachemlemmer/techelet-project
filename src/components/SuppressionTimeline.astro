---
// SuppressionTimeline.astro
// Two-track chronology: sumptuary/legal (left, gold) vs. persecution/military (right, red)

const legal = [
  { year: -215, label: '215 BCE', title: 'Lex Oppia',         desc: 'private purple banned during Punic War' },
  { year: -46,  label: '46 BCE',  title: 'Lex Julia',          desc: 'Caesar encodes supremacy in color' },
  { year: 301,  label: '301 CE',  title: 'Nationalization',    desc: 'Diocletian — gynaeciae, hereditary lock' },
  { year: 385,  label: '385 CE',  title: 'Death penalty',      desc: 'CTh 10.21.3 — private dyeing capital' },
  { year: 424,  label: '424 CE',  title: 'Confiscation order', desc: 'CTh 10.21.4 — all purple surrendered' },
  { year: 436,  label: '436 CE',  title: 'Coast surveilled',   desc: 'imperial inspectors to dye-houses' },
  { year: 470,  label: '470 CE',  title: 'Murex = death',      desc: 'CJ 1.23.6 — chilazon imperial property' },
  { year: 529,  label: '529 CE',  title: 'Hyacinthina named',  desc: 'Codex Justinianus — tekhelet listed by name' },
];

const persecution = [
  { year: 70,  label: '70 CE',   title: 'Temple destroyed',       desc: 'Vespasian — community contracts to Galilee' },
  { year: 135, label: '135 CE',  title: 'Bar Kokhba crushed',      desc: 'Hadrian — expelled from Jerusalem, שמד decrees' },
  { year: 315, label: '315 CE',  title: 'Persecution legislated',  desc: 'Constantine — Judaism "feral sect"' },
  { year: 339, label: '339 CE',  title: 'Gynaeciae weaponized',    desc: 'Constantius II — Jewish access to dye workers cut' },
  { year: 351, label: '351 CE',  title: 'Gallus revolt crushed',   desc: 'Galilean academies destroyed — supply severed' },
  { year: 553, label: '553 CE',  title: 'Novella 146',             desc: 'Mishnah reading prohibited' },
  { year: 614, label: '614 CE',  title: 'Wars devastate coast',    desc: 'Byzantine-Sassanid — murex coast shattered' },
  { year: 640, label: '640 CE',  title: 'Islamic conquest',        desc: 'Byzantine industry collapsed' },
];

const allEvents = [
  ...legal.map(e => ({ ...e, side: 'legal' })),
  ...persecution.map(e => ({ ...e, side: 'war' })),
].sort((a, b) => a.year - b.year);
---

<div class="tl2-wrap">
  <div class="tl2-header">
    <div class="tl2-track-label tl2-legal-lbl">Sumptuary · Legal</div>
    <div class="tl2-center-lbl">CHRONOLOGY OF SUPPRESSION</div>
    <div class="tl2-track-label tl2-war-lbl">Persecution · Military</div>
  </div>
  <div class="tl2-body">
    <div class="tl2-spine"></div>
    {allEvents.map((e) => (
      <div class:list={['tl2-row', `tl2-${e.side}`]}>
        <div class="tl2-left">
          {e.side === 'legal' && (
            <div>
              <b class="tl2-title">{e.title}</b>
              <span class="tl2-desc">{e.desc}</span>
            </div>
          )}
        </div>
        <div class="tl2-center">
          <div class="tl2-dot"></div>
          <div class="tl2-year">{e.label}</div>
        </div>
        <div class="tl2-right">
          {e.side === 'war' && (
            <div>
              <b class="tl2-title">{e.title}</b>
              <span class="tl2-desc">{e.desc}</span>
            </div>
          )}
        </div>
      </div>
    ))}
  </div>
  <div class="tl2-legend">
    <div class="tl2-leg tl2-legal"><span class="tl2-leg-dot"></span>sumptuary · legal</div>
    <div class="tl2-leg tl2-war"><span class="tl2-leg-dot"></span>persecution · military</div>
  </div>
</div>

<style>
  .tl2-wrap {
    width: 100%;
    margin: 2rem 0;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.1rem 1.2rem 0.9rem;
    background: var(--paper);
    font-family: Georgia, serif;
  }

  .tl2-header {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--border);
    align-items: center;
  }

  .tl2-track-label {
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    font-style: italic;
  }
  .tl2-legal-lbl { text-align: right; color: #b8860b; }
  .tl2-war-lbl   { text-align: left;  color: #8a2020; }

  .tl2-center-lbl {
    font-family: 'Courier New', monospace;
    font-size: 0.57rem;
    letter-spacing: 0.2em;
    color: #8a7a60;
    text-align: center;
    white-space: nowrap;
  }

  .tl2-body {
    position: relative;
  }

  .tl2-spine {
    position: absolute;
    left: 50%;
    top: 8px;
    bottom: 8px;
    width: 1px;
    background: var(--border);
    transform: translateX(-50%);
    z-index: 0;
  }

  .tl2-row {
    display: grid;
    grid-template-columns: 1fr 76px 1fr;
    align-items: start;
    margin-bottom: 0.6rem;
  }

  .tl2-center {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    position: relative;
    z-index: 1;
  }

  .tl2-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 1px;
  }
  .tl2-legal .tl2-dot { background: #b8860b; }
  .tl2-war   .tl2-dot { background: #8a2020; }

  .tl2-year {
    font-family: 'Courier New', monospace;
    font-size: 0.56rem;
    color: #6a5a48;
    text-align: center;
    line-height: 1.2;
  }

  .tl2-left {
    text-align: right;
    padding-right: 0.65rem;
    padding-top: 1px;
  }
  .tl2-right {
    text-align: left;
    padding-left: 0.65rem;
    padding-top: 1px;
  }

  .tl2-title {
    display: block;
    font-size: 0.67rem;
    font-weight: 700;
    line-height: 1.25;
  }
  .tl2-legal .tl2-title { color: #7a5a00; }
  .tl2-war   .tl2-title { color: #7a1818; }

  .tl2-desc {
    display: block;
    font-size: 0.57rem;
    color: #6a5a48;
    font-style: italic;
    line-height: 1.3;
    margin-top: 1px;
  }

  .tl2-legend {
    margin-top: 0.7rem;
    border-top: 1px solid var(--border);
    padding-top: 0.5rem;
    display: flex;
    justify-content: center;
    gap: 1.5rem;
  }

  .tl2-leg {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 0.57rem;
    color: #6a5a48;
    font-style: italic;
  }

  .tl2-leg-dot {
    display: inline-block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .tl2-legal .tl2-leg-dot { background: #b8860b; }
  .tl2-war   .tl2-leg-dot { background: #8a2020; }

  @media (max-width: 640px) {
    .tl2-row { grid-template-columns: 1fr 52px 1fr; }
    .tl2-desc { display: none; }
    .tl2-title { font-size: 0.61rem; }
    .tl2-center-lbl { font-size: 0.5rem; letter-spacing: 0.12em; }
  }
</style>
