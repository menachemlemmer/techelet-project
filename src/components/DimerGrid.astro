<div style="font-family:var(--ff-body);font-size:.9rem;line-height:1.8">
  <div style="display:grid;grid-template-columns:auto auto auto 1fr;align-items:center;gap:.5rem .75rem;margin:.5rem 0">
    <div style="font-family:var(--ff-mono);font-size:.8rem;color:var(--ink)">
      Indoxyl
    </div>
    <div style="color:var(--muted)">+</div>
    <div style="font-family:var(--ff-mono);font-size:.8rem;color:var(--ink)">
      Indoxyl
    </div>
    <div>
      → <b style="color:var(--ind)">Indigotin (IND)</b>
      <span style="color:var(--muted);font-size:.82rem">
        — no bromine. Identical to kala ilan.
      </span>
    </div>
    <div style="font-family:var(--ff-mono);font-size:.8rem;color:var(--ink)">
      Bromoindoxyl
    </div>
    <div style="color:var(--muted)">+</div>
    <div style="font-family:var(--ff-mono);font-size:.8rem;color:var(--ink)">
      Bromoindoxyl
    </div>
    <div>
      → <b style="color:var(--dbi)">6,6'-Dibromoindigo (DBI)</b>
      <span style="color:var(--muted);font-size:.82rem">
        — two bromines. Tyrian purple / argaman.
      </span>
    </div>
    <div style="font-family:var(--ff-mono);font-size:.8rem;color:var(--ink)">
      Indoxyl
    </div>
    <div style="color:var(--muted)">+</div>
    <div style="font-family:var(--ff-mono);font-size:.8rem;color:var(--ink)">
      Bromoindoxyl
    </div>
    <div>
      → <b style="color:var(--mbi)">6-Bromoindigo (MBI)</b>
      <span style="color:var(--muted);font-size:.82rem">
        — one bromine. The cross-product. Unique to <em>H. trunculus</em>.
      </span>
    </div>
  </div>
</div>
