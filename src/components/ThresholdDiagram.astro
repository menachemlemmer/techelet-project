<div class="threshold-diagram">
  <div style="font-family:var(--ff-mono);font-size:.65rem;color:var(--gold);letter-spacing:.1em;text-transform:uppercase;margin-bottom:.8rem">
    Stripping resistance
  </div>
  <div style="display:flex;align-items:center;gap:0;margin:.5rem 0 1.2rem">
    <div style="flex:2;height:28px;background:linear-gradient(to right,var(--ind),#4444aa);border-radius:4px 0 0 4px;display:flex;align-items:center;padding:0 8px">
      <span style="font-family:var(--ff-body);font-size:.78rem;color:white;font-weight:600">
        IND
      </span>
    </div>
    <div style="width:4px;height:44px;background:var(--gold2);position:relative">
      <div style="position:absolute;top:-20px;left:50%;transform:translateX(-50%);white-space:nowrap;font-family:var(--ff-mono);font-size:.65rem;color:var(--gold2)">
        TEST
      </div>
      <div style="position:absolute;top:-8px;left:50%;transform:translateX(-50%);font-size:1rem">
        ↓
      </div>
    </div>
    <div style="flex:2;height:28px;background:linear-gradient(to right,#4444aa,var(--mbi));display:flex;align-items:center;padding:0 8px">
      <span style="font-family:var(--ff-body);font-size:.78rem;color:white;font-weight:600">
        MBI
      </span>
    </div>
    <div style="flex:1;height:28px;background:linear-gradient(to right,var(--mbi),var(--dbi));border-radius:0 4px 4px 0;display:flex;align-items:center;padding:0 8px">
      <span style="font-family:var(--ff-body);font-size:.78rem;color:white;font-weight:600">
        DBI
      </span>
    </div>
  </div>
  <div style="display:flex;gap:1rem;margin-top:.3rem">
    <div style="flex:1;font-family:var(--ff-body);font-size:.8rem;color:#ef4444">
      ✗ Below threshold
      <br/>
      <span style="font-size:.75rem;opacity:.8">
        Fails Test 1 — color stripped
        <br/>→ identified as kala ilan
      </span>
    </div>
    <div style="flex:2;font-family:var(--ff-body);font-size:.8rem;color:#4ade80">
      ✓ Above threshold
      <br/>
      <span style="font-size:.75rem;opacity:.8">
        Survives Test 1 — color holds
        <br/>→ possibly authentic tekhelet
      </span>
    </div>
  </div>
</div>
