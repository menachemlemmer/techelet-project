---
interface Props {
  num?: string;
  title?: string;
  caption?: string;
  type?: 'blue' | 'gold' | 'violet' | 'green';
  borderless?: boolean;
}

const { num, title, caption, type, borderless = false } = Astro.props;
const classes = ['dp', type ? `dp-${type}` : '', borderless ? 'dp-borderless' : ''].filter(Boolean).join(' ');
---

<div class={classes}>
  {num && <div class="dp-num">{num}</div>}
  {title && <div class="dp-title">{title}</div>}
  <div class="svg-wrap">
    <slot />
  </div>
  {caption && <div class="dp-cap">{caption}</div>}
</div>
