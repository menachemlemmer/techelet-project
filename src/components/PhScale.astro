<div class="ph-section">
    <div class="ph-bar"></div>
    <div class="ph-tick-row">
      <div class="ph-tick">
        <span class="tick-val">0</span>
        <span class="tick-ex">Battery acid</span>
      </div>
      <div class="ph-tick">
        <span class="tick-val">2</span>
        <span class="tick-ex">Lemon juice</span>
      </div>
      <div class="ph-tick">
        <span class="tick-val">4</span>
        <span class="tick-ex">Vinegar</span>
      </div>
      <div class="ph-tick">
        <span class="tick-val">7</span>
        <span class="tick-ex">Pure water</span>
      </div>
      <div class="ph-tick">
        <span class="tick-val">9</span>
        <span class="tick-ex">Baking soda</span>
      </div>
      <div class="ph-tick">
        <span class="tick-val">11</span>
        <span class="tick-ex">Ammonia</span>
      </div>
      <div class="ph-tick">
        <span class="tick-val">12</span>
        <span class="tick-ex">Fermented urine</span>
      </div>
      <div class="ph-tick">
        <span class="tick-val">14</span>
        <span class="tick-ex">Lye</span>
      </div>
    </div>
  </div>
  <div class="ph-regions" style="margin-top:2rem">
    <div
      class="ph-region"
      style="background:#fff0f0;border:1.5px solid var(--crimson)"
    >
      <div class="ph-region-title" style="color:var(--crimson)">
        Acid (pH 0–6)
      </div>
      <div class="ph-region-body">
        Excess H⁺ ions. H⁺ can add to functional groups, keeping them protonated
        and uncharged. Molecules with C-OH or similar groups remain neutral. No
        water-attracting charge forms.
      </div>
    </div>
    <div
      class="ph-region"
      style="background:#f0fff4;border:1.5px solid #4a8a5a"
    >
      <div class="ph-region-title" style="color:#4a8a5a">
        Neutral (pH 7)
      </div>
      <div class="ph-region-body">
        H⁺ and OH⁻ in equal concentration. No net tendency to protonate or
        deprotonate functional groups.
      </div>
    </div>
    <div
      class="ph-region"
      style="background:#eaf2ff;border:1.5px solid var(--ind)"
    >
      <div class="ph-region-title" style="color:var(--ind)">
        Alkaline (pH 8–14)
      </div>
      <div class="ph-region-body">
        Excess OH⁻ ions. OH⁻ removes H⁺ from functional groups — deprotonation.
        A molecule that loses a proton gains a negative charge. Negatively
        charged molecules attract water strongly.
      </div>
    </div>
  </div>
