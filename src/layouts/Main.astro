---
import Sidebar from '../components/Sidebar.astro';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import '../styles/components.css';
import type { NavItem } from '../lib/navigation';

interface Props {
  sections: NavItem[];
  currentSlug: string;
}
const { sections, currentSlug } = Astro.props;
---
<!DOCTYPE html>
<html lang="en" data-theme="tekhelet">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>לבנת הספיר — Studies on Tekhelet</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,600;1,400&family=Noto+Serif+Hebrew&display=swap" rel="stylesheet" />
  <ClientRouter />
</head>
<body>
  <div class="drawer lg:drawer-open">
    <input id="sidebar-toggle" type="checkbox" class="drawer-toggle" />

    <div class="drawer-content flex flex-col">
      <!-- Mobile navbar -->
      <div class="navbar bg-neutral text-neutral-content lg:hidden sticky top-0 z-10">
        <label for="sidebar-toggle" class="btn btn-ghost btn-square">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-5 h-5 stroke-current"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
        </label>
        <span style="font-family:var(--ff-mono);font-size:0.6rem;color:#f0dca0;letter-spacing:0.08em;text-transform:uppercase">לבנת הספיר — Studies on Tekhelet</span>
      </div>

      <!-- Page content -->
      <div id="main">
        <div id="content" transition:animate="fade">
          <slot />
        </div>
      </div>
    </div>

    <!-- Sidebar -->
    <div class="drawer-side z-20">
      <label for="sidebar-toggle" aria-label="close sidebar" class="drawer-overlay"></label>
      <Sidebar sections={sections} currentSlug={currentSlug} />
    </div>
  </div>

  <script is:inline>
    // Preserve sidebar scroll position across view transitions
    document.addEventListener('astro:before-swap', () => {
      const sidebar = document.querySelector('[data-sidebar-nav]');
      if (sidebar) sessionStorage.setItem('sidebar-scroll', sidebar.scrollTop);
    });
    document.addEventListener('astro:after-swap', () => {
      const sidebar = document.querySelector('[data-sidebar-nav]');
      const saved = sessionStorage.getItem('sidebar-scroll');
      if (sidebar && saved) sidebar.scrollTop = parseInt(saved);
      initLightbox();
    });

    // Lightbox
    function initLightbox() {
      let overlay = document.getElementById('lb-overlay');
      if (!overlay) {
        overlay = document.createElement('div');
        overlay.id = 'lb-overlay';
        overlay.innerHTML = '<img id="lb-img" alt="" /><button id="lb-close" aria-label="Close">&#x2715;</button>';
        document.body.appendChild(overlay);
        overlay.addEventListener('click', closeLightbox);
        document.getElementById('lb-close').addEventListener('click', e => { e.stopPropagation(); closeLightbox(); });
        document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); });
      }
      const content = document.getElementById('content');
      if (!content) return;
      content.querySelectorAll('img').forEach(img => {
        img.addEventListener('click', () => {
          document.getElementById('lb-img').src = img.src;
          document.getElementById('lb-img').alt = img.alt || '';
          document.getElementById('lb-overlay').classList.add('lb-open');
        });
      });
    }

    function closeLightbox() {
      const overlay = document.getElementById('lb-overlay');
      if (overlay) overlay.classList.remove('lb-open');
    }

    initLightbox();
  </script>
</body>
</html>
